# ============================================================
# Unity .gitignore
# ============================================================

# ----- Unity Generated -----
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures can get large; exclude them.
[Mm]emory[Cc]aptures/

# Asset meta data should only be ignored when the corresponding
# file is also ignored.
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store
# tools plugin (note it has a capital "T" as a differentiator).
# !Assets/AssetStoreTools*

# Unity 3D project settings.
ProjectSettings/ProjectVersion.txt

# ----- Autogenerated VS/Rider Solution & Project Files -----
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files.
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ----- OS Generated -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ----- Visual Studio / Rider cache -----
.vs/
.idea/
*.swp
*.swo

# ----- Node (if any tooling is added) -----
node_modules/

# ----- Crash Reports -----
sysinfo.txt

# ----- Android / iOS Build Artifacts -----
*.apk
*.aab
*.ipa
*.unitypackage

# ----- Burst / IL2CPP Generated Code -----
/[Aa]ssets/[Ii][Ll]2[Cc][Pp][Pp]/
/[Aa]ssets/StreamingAssets/aa/

# ----- AddressableAssets Build -----
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.json*

# ----- TextMeshPro (do NOT ignore — contains required shader & font assets) -----
# Assets/TextMesh Pro/**  <-- keep this tracked

# ----- JetBrains Rider -----
.idea/

# ----- VSCode -----
.vscode/
